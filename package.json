{
  "name": "commit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "commit": "./src/index.ts"
  },
  "scripts": {
    "postinstall": "lefthook install",
    "start": "bun run src/index.ts",
    "lint": "bunx biome lint .",
    "lint:fix": "bunx biome lint --fix .",
    "fmt:fix": "bunx biome format --write .",
    "fmt:check": "bunx biome format .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "check:fast": "bun run fmt:check && bun run lint && bun run typecheck",
    "check": "bun run check:fast && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.9",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.79.6",
    "@earendil-works/pi-tui": "0.79.7",
    "typebox": "1.1.39"
  }
}
